# Root env for docker-compose. Copy to .env and edit — compose reads it
# automatically. Everything here has a safe local default, so this file is
# entirely optional; you only need it to change ports or add secrets.
#
#   cp .env.example .env

# Host port the app is served on → http://localhost:${WEB_PORT}
WEB_PORT=8080

# MongoDB credentials + database name
MONGO_USER=producthub
MONGO_PASSWORD=producthub
MONGO_DB=producthub

# API
NODE_ENV=production
JWT_SECRET=dev-secret-change-me      # CHANGE THIS for anything shared/online
JWT_EXPIRES_IN=7d
# Only relevant if you call the API cross-origin (the app itself is same-origin).
ALLOWED_ORIGINS=http://localhost:8080

# Optional: Azure Blob storage for bug attachments.
# Leave empty to store attachments inline (base64) instead.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=
