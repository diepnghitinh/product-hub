# Local development template. Copy to config/.env.local (gitignored) and adjust.
# These are the safe local-dev defaults the stack ships with.

NODE_ENV=local
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
APP_BASE_URL=http://localhost:3001
MAX_REQUEST_BODY_SIZE=10mb

JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

MONGODB_URI=mongodb://producthub:producthub@localhost:27017/producthub?authSource=admin
