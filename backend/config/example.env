# ─────────────────────────────────────────────────────────────────────────────
# Environment template.
#
# The app loads ONE file from this folder, chosen by NODE_ENV
# (see libs/shared/utils/dotenv.ts):
#   local (default) → config/.env.local
#   dev             → config/.env.dev
#   prod            → config/.env.prod
#
# Copy this file to the one you need (e.g. `cp config/example.env config/.env.local`)
# and fill in real values. The real .env.* files are gitignored (they hold
# secrets); only these example.* templates are committed.
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=local
PORT=3000
# Comma-separated web origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
# Base URL of the web app — used to build tappable links in outbound webhooks.
APP_BASE_URL=http://localhost:3001
# Max inbound JSON/form body (rich text can inline images). Optional, default 10mb.
MAX_REQUEST_BODY_SIZE=10mb

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# MongoDB
MONGODB_URI=mongodb://producthub:producthub@localhost:27017/producthub?authSource=admin
